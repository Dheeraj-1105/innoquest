rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Farmers can only read and write to their own profile.
    match /farmers/{farmerId} {
      allow read, write: if request.auth != null && request.auth.uid == farmerId;
    }

    // Farmers can read, write, update and delete their own advisories.
    match /farmers/{farmerId}/advisories/{advisoryId} {
      allow read, write: if request.auth != null && request.auth.uid == farmerId;
    }
    
    // Allow any authenticated user to read from public collections.
    match /crop_database/{docId} {
      allow read: if request.auth != null;
    }

    match /market_data/{docId} {
      allow read: if request.auth != null;
    }

    match /weather_data/{docId} {
      allow read: if request.auth != null;
    }
  }
}

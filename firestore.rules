/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for farmer profiles and their advisories,
 *              while allowing public read access to crop, market, and weather data.
 *
 * Data Structure:
 * - /farmers/{farmerId}: Farmer profile data, accessible only to the user with the matching UID.
 * - /crop_database/{cropDataId}: Publicly readable crop data.
 * - /market_data/{marketDataId}: Publicly readable market data.
 * - /farmers/{farmerId}/advisories/{advisoryId}: Farmer-specific advisories, accessible only to the owning farmer.
 * - /weather_data/{weatherDataId}: Publicly readable weather data.
 *
 * Key Security Decisions:
 * - User listing is disallowed; only individual farmer profiles can be accessed.
 * - Public read access is granted to crop, market, and weather data.
 * - Write access to crop, market, and weather data is implicitly denied, requiring explicit rules for specific roles if needed.
 * - Data validation is minimized for prototyping, focusing on ownership and relationship integrity.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for farmer profiles. Only the authenticated user can read or modify their own profile.
     * @path /farmers/{farmerId}
     * @allow (get, update, delete) if request.auth.uid == farmerId
     * @allow (create) if request.auth.uid == request.resource.data.id
     * @deny (get) if request.auth == null
     * @deny (create) if request.auth.uid != request.resource.data.id
     * @deny (update, delete) if request.auth == null
     * @principle Enforces document ownership for all operations.
     */
    match /farmers/{farmerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(farmerId) {
        return request.auth.uid == farmerId;
      }
      allow get: if isSignedIn() && isOwner(farmerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(farmerId);
      allow update: if isSignedIn() && isOwner(farmerId);
      allow delete: if isSignedIn() && isOwner(farmerId);
    }

    /**
     * @description Allows public read access to crop data. Write access is denied.
     * @path /crop_database/{cropDataId}
     * @allow (get, list) if true
     * @deny (create, update, delete) if true
     * @principle Provides public read access while restricting writes.
     */
    match /crop_database/{cropDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to market data. Write access is denied.
     * @path /market_data/{marketDataId}
     * @allow (get, list) if true
     * @deny (create, update, delete) if true
     * @principle Provides public read access while restricting writes.
     */
    match /market_data/{marketDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Enforces user-ownership for farmer advisories. Only the authenticated farmer can read or modify their own advisories.
     * @path /farmers/{farmerId}/advisories/{advisoryId}
     * @allow (get, list, create, update, delete) if request.auth.uid == farmerId
     * @deny (get, list, create, update, delete) if request.auth == null
     * @deny (create) if request.resource.data.farmerId != farmerId
     * @deny (update, delete) if resource.data.farmerId != farmerId
     * @principle Enforces document ownership for all operations.
     */
    match /farmers/{farmerId}/advisories/{advisoryId} {
     function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(farmerId) {
        return request.auth.uid == farmerId;
      }
      allow get: if isSignedIn() && isOwner(farmerId);
      allow list: if isSignedIn() && isOwner(farmerId);
      allow create: if isSignedIn() && isOwner(farmerId);
      allow update: if isSignedIn() && isOwner(farmerId);
      allow delete: if isSignedIn() && isOwner(farmerId);
    }

    /**
     * @description Allows public read access to weather data. Write access is denied.
     * @path /weather_data/{weatherDataId}
     * @allow (get, list) if true
     * @deny (create, update, delete) if true
     * @principle Provides public read access while restricting writes.
     */
    match /weather_data/{weatherDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
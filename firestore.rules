rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description This ruleset enforces a strict user-ownership model for farmer profiles.
     * @path /farmers/{userId}
     * @allow (read, write): Authenticated user can access their own profile.
     * @deny (read, write): Authenticated user cannot access another user's profile.
     * @principle Enforces document ownership for all operations within a user's profile path.
     */
    match /farmers/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && existsAfter(/databases/$(database)/documents/farmers/$(userId));
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants public read access to crop data, while restricting writes.
     * @path /crop_database/{cropDataId}
     * @allow (get, list): Any user can read crop data.
     * @deny (create, update, delete): No user can modify crop data.
     * @principle Enables public read access with enforced write restrictions.
     */
    match /crop_database/{cropDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Grants public read access to market data, while restricting writes.
     * @path /market_data/{marketDataId}
     * @allow (get, list): Any user can read market data.
     * @deny (create, update, delete): No user can modify market data.
     * @principle Enables public read access with enforced write restrictions.
     */
    match /market_data/{marketDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description This ruleset secures advisories for farmers, enabling read/write access only to the owner.
     * @path /farmers/{userId}/advisories/{advisoryId}
     * @allow (create): Authenticated user can create an advisory under their own user ID.
     * @allow (get, list): Authenticated user can read their own advisories.
     * @allow (update, delete): Authenticated user can update or delete their own existing advisories.
     * @deny (create, update, delete, get, list): All other cases are denied.
     * @principle Secures user-specific data in a subcollection with path-based rules.
     */
    match /farmers/{userId}/advisories/{advisoryId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && existsAfter(/databases/$(database)/documents/farmers/$(userId)/advisories/$(advisoryId));
      }
      allow get, list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants public read access to weather data, while restricting writes.
     * @path /weather_data/{weatherDataId}
     * @allow (get, list): Any user can read weather data.
     * @deny (create, update, delete): No user can modify weather data.
     * @principle Enables public read access with enforced write restrictions.
     */
    match /weather_data/{weatherDataId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}